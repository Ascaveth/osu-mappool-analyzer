# Copy to .env and fill in for local development. .env is gitignored —
# never commit real credentials. Both PORT and ALLOWED_ORIGINS are
# optional and default sensibly if unset (see internal/config).

PORT=8080
ALLOWED_ORIGINS=http://localhost:3000

# osu! API v2 credentials (client-credentials grant). Register an OAuth
# application at https://osu.ppy.sh/home/account/edit under "OAuth" — no
# callback URL is needed for this grant type. Leave both blank to run
# without star rating enrichment.
OSU_CLIENT_ID=
OSU_CLIENT_SECRET=
